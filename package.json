{
  "name": "autos",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5180",
    "build": "tsc -b && vite build",
    "browser:smoke": "npm exec -- tsx scripts/browser-smoke.ts",
    "audio:smoke": "npm exec -- tsx scripts/audio-smoke.ts",
    "physics:reality": "npm exec -- tsx scripts/reality-smoke.ts",
    "lint": "eslint .",
    "physics:bounce": "node scripts/smoke-bounce.mjs",
    "physics:runtime": "npm exec -- tsx scripts/physics-runtime.ts",
    "physics:scenarios": "npm exec -- tsx scripts/physics-scenarios.ts",
    "vehicle:catalog": "npm exec -- tsx scripts/smoke-vehicle-catalog.ts",
    "maps:smoke": "npm exec -- tsx scripts/smoke-maps.ts",
    "preview": "vite preview",
    "verify:builds": "npm exec -- tsx scripts/verify-vehicle-builds.ts",
    "validate": "npm run lint && npm run build && npm run physics:bounce && npm run physics:runtime && npm run maps:smoke && npm run verify:builds && npm run vehicle:catalog"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/rapier": "^2.2.0",
    "@supabase/supabase-js": "^2.98.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "three": "^0.183.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "playwright": "^1.58.2",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
